# Wangpan deployment environment example.
# Copy this file to .env on the main VPS, then replace every replace-* value.
# Keep the real .env private. It contains the database password, cookie secret,
# app master key, bootstrap admin password, and storage-agent tokens.

# ---------------------------------------------------------------------------
# Main VPS: Web + API + PostgreSQL + local storage-agent
# ---------------------------------------------------------------------------

# Required. The API reads APP_MASTER_KEY, not MASTER_KEY. Must decode to
# exactly 32 bytes. Generate base64 with:
#   openssl rand -base64 32
# A 64-character hex key is also accepted by the API.
# Back this value up offline. Losing it makes encrypted files unrecoverable.
APP_MASTER_KEY=replace-with-output-of-openssl-rand-base64-32

# Required. Used for signed auth cookies. Generate with:
#   openssl rand -base64 48
COOKIE_SECRET=replace-with-a-long-random-cookie-secret

# Use false for plain HTTP/IP testing. Set true only when the site is served
# over HTTPS by your reverse proxy.
COOKIE_SECURE=false

# Required. PostgreSQL password used by docker-compose.main.yml.
POSTGRES_PASSWORD=replace-with-a-database-password

# External URL of the web app. For production, use your HTTPS origin.
CORS_ORIGIN=http://localhost:8080
PUBLIC_BASE_URL=http://localhost:8080

# Optional tuning.
SESSION_TTL_DAYS=14
MAX_UPLOAD_BYTES=536870912

# Standalone API deployments, without docker-compose.main.yml, must also set:
# DATABASE_URL=postgresql://wangpan:replace-with-a-database-password@127.0.0.1:5432/wangpan
# PORT=4000
# HOST=0.0.0.0

# First admin user. The API creates this user only when the user table is empty.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-at-least-10-chars

# Local storage-agent registered automatically by the API on first startup.
BOOTSTRAP_LOCAL_NODE_NAME=main-local
BOOTSTRAP_LOCAL_NODE_URL=http://storage-agent-local:4010
LOCAL_AGENT_TOKEN=replace-with-at-least-24-random-chars-for-main-local-agent

# ---------------------------------------------------------------------------
# Remote storage-agent VPS
# ---------------------------------------------------------------------------
# On a remote storage-agent VPS, create a separate .env containing only this
# section. The agent stores ciphertext objects under /data/objects in the
# container, backed by the docker volume named agent-data.
#
# Recommended network:
# - same LAN/VPC/private IP now, for example http://10.0.0.2:4010
# - WireGuard private IP for cross-provider VPS later
# - TLS if exposing any agent endpoint across untrusted networks

NODE_ID=remote-vps-1
AGENT_TOKEN=replace-with-at-least-24-random-chars
AGENT_MAX_OBJECT_BYTES=1073741824

# Standalone storage-agent deployments, without docker-compose.agent.yml, may set:
# AGENT_DATA_DIR=/data/objects
# PORT=4010
# HOST=0.0.0.0
